{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "coverage", "findings", "next_steps"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["APPROVED", "CHANGES_REQUESTED"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["correctness", "security", "reliability", "simplification", "performance"],
      "properties": {
        "correctness": { "type": "integer", "minimum": 0 },
        "security": { "type": "integer", "minimum": 0 },
        "reliability": { "type": "integer", "minimum": 0 },
        "simplification": { "type": "integer", "minimum": 0 },
        "performance": { "type": "integer", "minimum": 0 }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "lens", "file", "line_start", "line_end", "severity", "confidence", "issue", "suggestion", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^R[0-9]+F[0-9]+$" },
          "lens": {
            "type": "string",
            "enum": ["correctness", "security", "reliability", "simplification", "performance"]
          },
          "file": { "type": "string", "minLength": 1 },
          "line_start": { "type": "integer", "minimum": 1 },
          "line_end": { "type": "integer", "minimum": 1 },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "issue": { "type": "string", "minLength": 1 },
          "suggestion": { "type": "string", "minLength": 1 },
          "status": {
            "type": ["string", "null"],
            "enum": ["resolved", "open", "superseded"]
          }
        }
      }
    },
    "next_steps": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    }
  }
}
